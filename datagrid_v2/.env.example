# ── clingrid v2 — Sponsor Track Environment Variables ────────────────────────

# ── HydraDB (replaces Ghost DB) ───────────────────────────────────────────────
# Get your key at: https://console.hydradb.com
HYDRADB_API_KEY=your_hydradb_api_key_here

# ── Dify (replaces OverClaw + custom orchestrator) ────────────────────────────
# Workflow API key from: https://cloud.dify.ai → your app → API Keys
DIFY_API_KEY=app-EvEgLFOwr3XYAZRNLBSTm3Va
DIFY_BASE_URL=https://api.dify.ai/v1
# Public workflow URL (for reference): https://udify.app/workflow/1mo5zEraYy0xtRaw

# ── GMI Cloud (replaces Groq) ─────────────────────────────────────────────────
# Get your key at: https://console.gmicloud.ai
# API is fully OpenAI-compatible: https://api.gmi-serving.com/v1
GMI_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_MODEL=moonshotai/Kimi-K2-Instruct
# Alternative models: deepseek-ai/DeepSeek-R1, meta-llama/Llama-3.3-70B-Instruct

# ── Photon (replaces Airbyte for notifications) ───────────────────────────────
# Get your key at: https://photon.so/dashboard
# Required only for iMessage hospital notifications (optional)
PHOTON_API_KEY=your_photon_api_key_here

# ── Auth0 (unchanged) ─────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_m2m_client_id
AUTH0_CLIENT_SECRET=your_m2m_client_secret
AUTH0_AUDIENCE=https://api.clingrid.health

# ── App ───────────────────────────────────────────────────────────────────────
CLINGRID_DATA_DIR=../data/synthetic
CLINGRID_OUTPUT_DIR=./output
LOG_LEVEL=INFO
